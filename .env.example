# Salin file ini jadi .env dan isi dengan nilai asli. JANGAN commit .env ke git.

PANDORA_BASE_URL=https://your-pandora-instance.example.com/pandora_console
PANDORA_API_USER=your_api_user
PANDORA_API_USER_PASS=your_api_user_password
PANDORA_API_PASSWORD=your_api_password_from_general_setup

# Opsional, untuk konfigurasi app
APP_ENV=development
APP_PORT=8000
